# backend/.env.example
#
# Copy to `.env` (gitignored) and fill in the values you need.
#
# This file is regenerated by greping every ``os.environ.get(...)`` /
# ``os.getenv(...)`` / ``os.environ[...]`` in backend/app. If you add a
# new env var in code, add it here at the same time — the frontend
# audit caught significant drift between this file and actual usage.
#
# Every var has a sensible default baked into the code, so you only
# need to set the ones relevant to your setup (local Gemma vs cloud
# chat vs OlmoEarth inference).


# ============================================================
# LOCAL LLM (Gemma) — gemma_client.py
# ============================================================

# Which lifecycle the backend speaks for local Gemma:
#   vllm    — (default) vLLM server you start in WSL/Docker; backend
#             only health-checks and chats.
#   ollama  — Ollama lifecycle (pull / ps / stop) — Windows-native.
#   cloud   — GEMMA_BASE_URL points at a hosted OpenAI-compat endpoint.
# Auto-detects when unset: non-localhost URL → cloud, :11434 → ollama.
LLM_RUNTIME=vllm

# OpenAI-compatible endpoint for the LOCAL Gemma path (not for the 4
# dedicated cloud chat providers below — those have their own vars).
# Defaults to the vLLM container port this backend spins up.
GEMMA_BASE_URL=http://localhost:8001/v1

# HuggingFace model id served by the local runtime.
# Ungated (no HF token): unsloth/gemma-4-{e2b,e4b}-it, unsloth/gemma-4-26b-a4b-it(-bnb-4bit)
# Gated (needs HF_TOKEN): google/gemma-4-{e4b,26b}-it / -a4b-it
GEMMA_MODEL=unsloth/gemma-4-e4b-it

# API key for the local Gemma endpoint if it requires one. Falls back
# to OPENAI_API_KEY when unset (useful if you're routing local-Gemma
# traffic through an OpenAI-compat proxy that reuses the same key).
GEMMA_API_KEY=

GEMMA_TIMEOUT=120     # per-request HTTP timeout, seconds
GEMMA_PORT=8001       # published port for the vLLM container

# Custom vLLM image + container name (leave empty for defaults).
VLLM_IMAGE=geoenv-vllm:latest
VLLM_CONTAINER_NAME=geoenv-llm

# Path to the directory that holds the Dockerfile the backend builds
# when ``docker.image_built`` is false. Override if you keep a custom
# Dockerfile elsewhere (must be an absolute path inside the backend
# container's filesystem / WSL mount).
# VLLM_DOCKERFILE_DIR=

# Host HuggingFace cache root. Auto-detected via ``~/.cache/huggingface``
# if unset; override for shared-disk or non-default cache layouts.
# HF_CACHE_DIR=


# ============================================================
# HUGGINGFACE — FT / dataset downloads
# ============================================================

# Token for gated repos (google/gemma-*, meta-llama/*, some OlmoEarth
# FT heads). ``HUGGINGFACE_HUB_TOKEN`` is the fallback alias the
# code checks if HF_TOKEN is unset.
HF_TOKEN=
# HUGGINGFACE_HUB_TOKEN=


# ============================================================
# CLOUD CHAT PROVIDERS
# ------------------------------------------------------------
# All four are independent — set only the ones you plan to use.
# Users can also paste an API key into the per-provider UI config
# at runtime, which overrides the env var for that session only.
# ============================================================

# --- NVIDIA NIM (cloud_llm_client.py) ---
# Free tier + developer credits at https://build.nvidia.com
# Default model: MiniMax M2.7 — live-verified April 2026 as the NIM
# free-tier model with the cleanest tool-calling behavior.
# Alternatives (in rough descending recommendation order): minimaxai/
# minimax-m2.5, openai/gpt-oss-{20b,120b}, meta/llama-3.3-70b-instruct,
# deepseek-ai/deepseek-v3.1, qwen/qwen3-32b-instruct.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=minimaxai/minimax-m2.7
NVIDIA_TIMEOUT=120

# --- Anthropic Claude (claude_client.py) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_TIMEOUT=120

# --- Google Gemini (gemini_client.py) via OpenAI-compat endpoint ---
# https://aistudio.google.com/apikey — GEMINI_API_KEY is preferred,
# GOOGLE_API_KEY is the fallback alias the code checks.
GEMINI_API_KEY=
# GOOGLE_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=120

# --- OpenAI ChatGPT (openai_client.py) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT=120
# Optional enterprise scoping headers — leave empty for personal keys.
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
